    <owl:DatatypeProperty rdf:about="http://www.noel-garcia.org/ontologies/medical-devices#reportDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.noel-garcia.org/ontologies/medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date when the incident was reported.</rdfs:comment>
        <rdfs:label>report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.noel-garcia.org/ontologies/medical-devices#riskName -->


    <owl:DatatypeProperty rdf:about="http://www.noel-garcia.org/ontologies/medical-devices#riskName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.noel-garcia.org/ontologies/medical-devices#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name describing the risk.</rdfs:comment>
        <rdfs:label>risk name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.noel-garcia.org/ontologies/medical-devices#scope -->


    <owl:DatatypeProperty rdf:about="http://www.noel-garcia.org/ontologies/medical-devices#scope">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.noel-garcia.org/ontologies/medical-devices#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Scope of the corrective action.</rdfs:comment>
        <rdfs:label>scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.noel-garcia.org/ontologies/medical-devices#status -->


    <owl:DatatypeProperty rdf:about="http://www.noel-garcia.org/ontologies/medical-devices#status">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.noel-garcia.org/ontologies/medical-devices#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Current status of the corrective action.</rdfs:comment>
        <rdfs:label>status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.noel-garcia.org/ontologies/medical-devices#udi_di -->


    <owl:DatatypeProperty rdf:about="http://www.noel-garcia.org/ontologies/medical-devices#udi_di">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.noel-garcia.org/ontologies/medical-devices#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The unique device identifier.</rdfs:comment>
        <rdfs:label>udi_di</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.org/#email -->


    <owl:DatatypeProperty rdf:about="https://schema.org/#email">
        <rdfs:domain rdf:resource="http://www.noel-garcia.org/ontologies/medical-devices#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The contact email address of the manufacturer.</rdfs:comment>
        <rdfs:label>email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.org/#name -->


    <owl:DatatypeProperty rdf:about="https://schema.org/#name">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.noel-garcia.org/ontologies/medical-devices#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The official name of the manufacturer.</rdfs:comment>
        <rdfs:label>name</rdfs:label>
    </owl:DatatypeProperty>
    


