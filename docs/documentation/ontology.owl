<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.noel-garcia.org/ontologies/medical-devices#"
     xml:base="http://www.noel-garcia.org/ontologies/medical-devices"
     xmlns:mod="https://w3id.org/mod#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="https://schema.org/"
     xmlns:schema1="https://schema.org/#"
     xmlns:medical-devices="http://www.noel-garcia.org/ontologies/medical-devices#">
    <owl:Ontology rdf:about="http://www.noel-garcia.org/ontologies/medical-devices">
        <owl:versionIRI rdf:resource="http://www.noel-garcia.org/ontologies/medical-devices/1.0.0"/>
        <terms:bibliographicCitation xml:lang="en">Noël García Pou (2026) - Medical Devices Ontology - UOC Project</terms:bibliographicCitation>
        <terms:created>2026-04-04</terms:created>
        <terms:creator>Noël García Pou</terms:creator>
        <terms:description xml:lang="en">European high-risk medical devices.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-27</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:publisher>Noël García Pou</terms:publisher>
        <terms:source rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.noel-garcia.org/ontologies/medical-devices</terms:source>
        <terms:title xml:lang="en">PAC2 - Medical Devices and Incidents</terms:title>
        <vann:preferredNamespacePrefix>mdo</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://www.noel-garcia.org/ontologies/medical-devices</vann:preferredNamespaceUri>
        <owl:versionInfo>1.0.0</owl:versionInfo>
        <schema:logo rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://upload.wikimedia.org/wikipedia/commons/a/a3/Logo_blau_uoc.png</schema:logo>
        <mod:createdWith rdf:resource="https://chowlk.linkeddata.es/"/>
        <mod:status xml:lang="en">Project submission</mod:status>
    </owl:Ontology>
    


