        <rdf:type rdf:resource="http://www.noel-garcia.org/ontologies/medical-devices#ActiveDevice"/>
        <rdfs:comment xml:lang="en">Device category used to define its use.</rdfs:comment>
        <rdfs:label>Active_Device_Type</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.noel-garcia.org/ontologies/medical-devices#Active_Implant_Type -->


    <owl:NamedIndividual rdf:about="http://www.noel-garcia.org/ontologies/medical-devices#Active_Implant_Type">
        <rdf:type rdf:resource="http://www.noel-garcia.org/ontologies/medical-devices#ActiveImplant"/>
        <rdfs:comment xml:lang="en">Device category used to define its use.</rdfs:comment>
        <rdfs:label xml:lang="en">Active_Implant_Type</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.noel-garcia.org/ontologies/medical-devices#Class_A -->


    <owl:NamedIndividual rdf:about="http://www.noel-garcia.org/ontologies/medical-devices#Class_A">
        <rdf:type rdf:resource="http://www.noel-garcia.org/ontologies/medical-devices#ClassA"/>
        <rdfs:comment xml:lang="en">Standardized classification values for In Vitro Diagnostic (IVD) devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Class_A</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.noel-garcia.org/ontologies/medical-devices#Class_B -->


