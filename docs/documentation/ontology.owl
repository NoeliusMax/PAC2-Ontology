        <rdfs:comment xml:lang="en">Links a manufacturer with its devices.</rdfs:comment>
        <rdfs:label xml:lang="en">is manufacturer of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.noel-garcia.org/ontologies/medical-devices#isProbabilityOf -->


