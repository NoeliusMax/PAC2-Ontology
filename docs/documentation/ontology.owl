        <devicesAffected rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">850</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000001</eudamedFSCARef>
        <scope>All HeartMate 3 LVAD units implanted since 2020</scope>
        <status>Open</status>
