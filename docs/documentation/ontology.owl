    <!-- http://purl.org/dc/terms/description -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/description">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.noel-garcia.org/ontologies/medical-devices#CorrectiveAction"/>
                    <rdf:Description rdf:about="http://www.noel-garcia.org/ontologies/medical-devices#Incident"/>
                    <rdf:Description rdf:about="http://www.noel-garcia.org/ontologies/medical-devices#Risk"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
    </owl:DatatypeProperty>
    


